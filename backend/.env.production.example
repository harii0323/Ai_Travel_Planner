# Production Environment Template
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production or actual secrets to version control!

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production
LOG_LEVEL=info
DEPLOY_VERSION=1.0.0

# ============================================
# SERVER
# ============================================
PORT=5000
API_BASE_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ============================================
# DATABASE (MongoDB)
# ============================================
# For MongoDB Atlas (Cloud - Recommended)
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/ai-travel-planner?retryWrites=true&w=majority

# For Self-Hosted MongoDB
# MONGODB_URI=mongodb://username:password@your-server:27017/ai-travel-planner

# Connection pool settings
MONGODB_CONNECTION_POOL=50
MONGODB_TIMEOUT=30000

# ============================================
# AUTHENTICATION
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_key_here_minimum_32_characters

# JWT expiration
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Bcrypt rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# ============================================
# SESSION
# ============================================
SESSION_SECRET=your_session_secret_key_here

# ============================================
# CORS
# ============================================
CORS_ORIGIN=https://yourdomain.com
CORS_CREDENTIALS=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_ATTEMPTS=5

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
EMAIL_SERVICE=gmail
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=AI Travel Planner <noreply@yourdomain.com>

# ============================================
# LOGGING & MONITORING
# ============================================
# Sentry for error tracking
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Log file paths
LOG_FILE=./logs/app.log
ERROR_LOG_FILE=./logs/error.log
ACCESS_LOG_FILE=./logs/access.log

# ============================================
# CACHING (Optional)
# ============================================
REDIS_HOST=redis.yourdomain.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_TTL=3600

# ============================================
# AWS (If using AWS services - optional)
# Render deployments do not require these settings. Remove or leave blank.
# ============================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=your-travel-planner-bucket

# ============================================
# STRIPE (If adding payments later)
# ============================================
STRIPE_PUBLIC_KEY=pk_live_your_key
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# ============================================
# THIRD-PARTY APIs
# ============================================
# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Weather API
OPENWEATHER_API_KEY=your_openweather_api_key

# ============================================
# CDN & STATIC FILES
# ============================================
CDN_URL=https://cdn.yourdomain.com
STATIC_FILES_CACHE_TIME=31536000

# ============================================
# SECURITY
# ============================================
# HTTPS enforcement
FORCE_HTTPS=true
HSTS_MAX_AGE=31536000

# Content Security Policy
CSP_REPORT_URI=https://your-csp-report-collector.com

# ============================================
# MAINTENANCE MODE
# ============================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=We are currently performing maintenance. Please check back soon!

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_SOCIAL_SHARING=true
FEATURE_ANALYTICS=true
FEATURE_PREMIUM=false

# ============================================
# SITE CONFIG
# ============================================
SITE_NAME=AI Travel Planner
SITE_DESCRIPTION=Budget-friendly travel itineraries for students
SITE_URL=https://yourdomain.com

# ============================================
# ANALYTICS
# ============================================
GOOGLE_ANALYTICS_ID=G-your-id
MIXPANEL_TOKEN=your_mixpanel_token

# ============================================
# SUPPORT
# ============================================
SUPPORT_EMAIL=support@yourdomain.com
HELP_DESK_URL=https://help.yourdomain.com
